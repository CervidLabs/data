    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node test/compare.js"
  },
  "keywords": [
    "dataframe",
    "parallel",
    "sharedarraybuffer",
    "big-data",
    "data-analysis",
    "typescript",
    "columnar-storage",
    "multithreading",
    "performance"
  ],
  "author": "Aldair Beltran",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}