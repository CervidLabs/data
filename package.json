{
  "name": "octopus",
  "version": "1.0.0",
  "description": "High-performance parallel data engine for Node.js using SharedArrayBuffers and lock-free atomic synchronization.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
